/* DEPOIMENTOS CAROUSEL */
(function(){
  const wrap=document.querySelector('.depo-carousel-wrap');
  if(!wrap)return;
  const track=wrap.querySelector('.depo-track');
  const cards=Array.from(track.querySelectorAll('.depo-card'));
  const dots=Array.from(wrap.querySelectorAll('.depo-dot'));
  let cur=0,timer;
  function vis(){return window.innerWidth<=768?1:3}
  function maxI(){return Math.max(0,cards.length-vis())}
  function goTo(n){
    n=Math.max(0,Math.min(n,maxI()));
    cur=n;
    const w=cards[0].offsetWidth+24;
    track.style.transform='translateX(-'+(cur*w)+'px)';
    dots.forEach((d,i)=>d.classList.toggle('active',i===cur));
  }
  function next(){goTo(cur>=maxI()?0:cur+1)}
  function start(){timer=setInterval(next,4500)}
  function stop(){clearInterval(timer)}
  dots.forEach((d,i)=>d.addEventListener('click',()=>{goTo(i);stop();start()}));
  let sx=0;
  track.addEventListener('touchstart',e=>{sx=e.touches[0].clientX;stop()},{passive:true});
  track.addEventListener('touchend',e=>{
    const dx=e.changedTouches[0].clientX-sx;
    if(Math.abs(dx)>40)dx<0?next():goTo(cur-1);
    start();
  },{passive:true});
  window.addEventListener('resize',()=>goTo(cur));
  start();
})();

