<style>
:root {
  --blue:       #2E9E22;
  --blue-dark:  #133F09;
  --blue-mid:   #2E9E22;
  --blue-light: #63C74D;
  --blue-pale:  #EAF7E6;
  --teal:       #F2A900;
  --amber:      #FBCE00;
  --cta:        #2E9E22;
  --cta-dark:   #23801A;
  --gray-bg:    #F5FBF3;
  --text:       #133F09;
  --white:      #ffffff;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Nunito',sans-serif;color:var(--text);overflow-x:hidden}
a{text-decoration:none;color:inherit}
img{max-width:100%;display:block}

/* TOPBAR */
.topbar{
  position:fixed;top:0;left:0;right:0;z-index:101;
  background:linear-gradient(90deg,#133F09 0%,#2E9E22 35%,#F2A900 50%,#2E9E22 65%,#133F09 100%);
  background-size:300% 100%;
  animation:topbarShine 5s ease infinite;
  height:52px;display:flex;align-items:center;justify-content:center;
  gap:20px;padding:0 20px;overflow:hidden;
  box-shadow:0 2px 16px rgba(46,158,34,0.6);
}
.topbar::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.18) 50%,transparent 100%);
  animation:shimmer 2s linear infinite;pointer-events:none;
}
.topbar::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,rgba(242,169,0,0.8),white,rgba(242,169,0,0.8),transparent);
  animation:shimmer 2s linear infinite;
}
@keyframes topbarShine{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
@keyframes shimmer{0%{transform:translateX(-150%)}100%{transform:translateX(150%)}}
.topbar-text{font-size:13.5px;font-weight:700;color:white;white-space:nowrap;letter-spacing:.4px;text-shadow:0 1px 8px rgba(0,0,0,.4)}
.topbar-text .fire{animation:fireShake .6s ease infinite;display:inline-block;font-size:16px;filter:drop-shadow(0 0 6px rgba(255,180,0,.8))}
@keyframes fireShake{0%{transform:rotate(-10deg) scale(1)}25%{transform:rotate(0deg) scale(1.15)}50%{transform:rotate(10deg) scale(1)}75%{transform:rotate(0deg) scale(1.1)}100%{transform:rotate(-10deg) scale(1)}}
.topbar-text-mobile{display:none}
.topbar-countdown{display:flex;align-items:center;gap:4px}
.countdown-block{display:flex;flex-direction:column;align-items:center;background:rgba(0,0,0,.35);border-radius:7px;padding:3px 10px;min-width:44px;border:1px solid rgba(255,255,255,.25);box-shadow:0 0 12px rgba(242,169,0,.4),inset 0 1px 0 rgba(255,255,255,.1)}
.countdown-num{font-family:'Nunito',sans-serif;font-size:19px;font-weight:900;color:white;line-height:1;font-variant-numeric:tabular-nums;transition:transform .12s ease,opacity .12s ease;text-shadow:0 0 10px rgba(242,169,0,.9)}
.countdown-num.flip{transform:translateY(-5px);opacity:0}
.countdown-label{font-size:8px;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.8px;font-weight:700;margin-top:1px}
.countdown-sep{font-size:20px;font-weight:900;color:white;margin-bottom:6px;animation:blinkSep 1s step-end infinite;text-shadow:0 0 8px rgba(242,169,0,.9)}
@keyframes blinkSep{0%,100%{opacity:1}50%{opacity:.15}}
.topbar-cta{background:white;color:var(--blue-dark);font-size:12.5px;font-weight:900;padding:7px 18px;border-radius:50px;white-space:nowrap;transition:all .2s;text-transform:uppercase;letter-spacing:.5px;animation:ctaPulse 2.5s ease infinite;box-shadow:0 0 0 0 rgba(255,255,255,.7)}
@keyframes ctaPulse{0%{box-shadow:0 0 0 0 rgba(255,255,255,.7)}60%{box-shadow:0 0 0 8px rgba(255,255,255,0)}100%{box-shadow:0 0 0 0 rgba(255,255,255,0)}}
.topbar-cta:hover{background:#FFF0C2;transform:scale(1.08);animation:none}

/* NAV */
.nav{position:fixed;top:52px;left:0;right:0;z-index:100;background:var(--blue-dark);height:80px;display:flex;align-items:center;box-shadow:0 2px 24px rgba(0,0,0,.3)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 32px;width:100%;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:12px}
.nav-logo-img{height:60px;width:auto;max-width:240px;transition:transform .3s}
.nav-logo:hover .nav-logo-img{transform:scale(1.04)}
.nav-logo-text{display:flex;flex-direction:column}
.nav-logo-name{font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;color:white;letter-spacing:-.5px;line-height:1}
.nav-logo-tagline{font-size:11px;color:rgba(255,255,255,.55);letter-spacing:1.5px;text-transform:uppercase}
.nav-actions{display:flex;align-items:center;gap:10px}
.nav-menu{display:flex;align-items:center;gap:10px}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:44px;height:44px;border:none;background:rgba(255,255,255,.12);border-radius:12px;cursor:pointer;padding:0}
.nav-burger span{display:block;width:20px;height:2px;background:#fff;border-radius:2px;transition:transform .25s,opacity .2s;margin:0 auto}
.nav-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-burger.open span:nth-child(2){opacity:0}
.nav-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.nav-central{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.8);font-size:13px;font-weight:700;padding:8px 14px;border-radius:50px;border:1px solid rgba(255,255,255,.2);transition:all .2s}
.nav-central:hover{background:rgba(255,255,255,.1);color:white}
.nav-cta{background:var(--cta);color:white;font-size:14px;font-weight:800;padding:10px 24px;border-radius:50px;transition:all .25s;text-transform:uppercase;letter-spacing:.3px;white-space:nowrap}
.nav-cta:hover{background:var(--cta-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(242,169,0,.4)}
.nav-cta-short{display:none}

/* HERO */
.hero-carousel{margin-top:132px;position:relative;height:620px;min-height:500px;overflow:hidden}
.hero-slide{position:absolute;inset:0;background-size:cover;background-position:center;display:flex;align-items:flex-end;opacity:0;transition:opacity .8s ease}
.hero-slide.active{opacity:1}
#slide1{background-image:url('hero.jpg');background-size:cover;background-position:center}
#slide2{background-image:url('hero2.jpg');background-size:cover;background-position:center}
.hero-fiber-lines{position:absolute;inset:0;opacity:.5;pointer-events:none}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,35,5,.5) 0%,transparent 55%),linear-gradient(to right,rgba(10,35,5,.55) 0%,rgba(10,35,5,.15) 45%,transparent 70%)}
.hero-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:0 32px 64px;width:100%}
.hero-content{max-width:560px}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(242,169,0,.2);border:1px solid rgba(242,169,0,.4);color:#FBCE00;font-size:12px;font-weight:700;padding:6px 14px;border-radius:50px;margin-bottom:18px;text-transform:uppercase;letter-spacing:.5px;backdrop-filter:blur(4px)}
.hero-title{font-family:'Nunito',sans-serif;font-size:clamp(34px,5vw,58px);font-weight:900;color:white;line-height:1.05;text-transform:uppercase;margin-bottom:16px;text-shadow:0 2px 20px rgba(0,0,0,.3)}
.hero-title .accent{color:var(--teal)}
.hero-sub{font-size:17px;color:rgba(255,255,255,.85);line-height:1.6;margin-bottom:32px;max-width:460px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--cta);color:white;font-family:'Nunito',sans-serif;font-size:15px;font-weight:800;padding:15px 32px;border-radius:50px;transition:all .25s;text-transform:uppercase;letter-spacing:.3px;box-shadow:0 8px 28px rgba(242,169,0,.4)}
.btn-primary:hover{background:var(--cta-dark);transform:translateY(-3px);box-shadow:0 12px 36px rgba(242,169,0,.5)}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:white;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;padding:14px 28px;border-radius:50px;border:2px solid rgba(255,255,255,.4);transition:all .2s;cursor:pointer}
.btn-outline:hover{border-color:white;background:rgba(255,255,255,.1)}
.hero-dots{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3}
.hero-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.35);cursor:pointer;transition:all .3s}
.hero-dot.active{background:var(--teal);width:24px;border-radius:4px}

/* COMBO BAR */
.combo-bar{background:var(--blue);padding:0}
.combo-bar-inner{max-width:1200px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:center;height:56px;gap:0}
.combo-item{display:flex;align-items:center;gap:10px;color:white;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:0 28px;white-space:nowrap}
.combo-icon{display:flex;align-items:center;color:var(--teal);flex-shrink:0}
.combo-divider{width:1px;height:22px;background:rgba(255,255,255,.2);flex-shrink:0}

/* VIA SECTION */
.via-section{background:white;padding:64px 0;border-top:1px solid #EAF7E6;border-bottom:1px solid #EAF7E6}
.via-section-inner{max-width:640px;margin:0 auto;padding:0 24px;text-align:center}
.via-section-badge{display:inline-flex;align-items:center;gap:8px;background:var(--blue-pale);color:var(--blue);font-size:12px;font-weight:800;padding:6px 16px;border-radius:50px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:20px}
.via-section-title{font-family:'Nunito',sans-serif;font-size:clamp(26px,4.5vw,40px);font-weight:900;color:var(--blue-dark);line-height:1.15;margin-bottom:12px}
.via-section-title .accent{color:var(--blue)}
.via-section-sub{font-size:16px;color:#556B4C;margin-bottom:36px;line-height:1.6}
.btn-via{display:inline-flex;align-items:center;gap:10px;background:var(--blue);color:white;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;padding:17px 40px;border-radius:50px;cursor:pointer;border:none;transition:all .25s;box-shadow:0 8px 28px rgba(46,158,34,.35);text-transform:uppercase;letter-spacing:.5px;animation:ctaPulse 2.5s ease infinite}
.btn-via:hover{background:var(--blue-dark);transform:translateY(-3px);box-shadow:0 14px 40px rgba(46,158,34,.45);animation:none}

/* STATS */
.stats{background:var(--gray-bg);padding:64px 0}
.stats-grid{max-width:1200px;margin:0 auto;padding:0 32px;display:grid;grid-template-columns:repeat(4,1fr)}
.stat-item{text-align:center;padding:32px 24px;border-right:1px solid #DEEFD8}
.stat-item:last-child{border-right:none}
.stat-number{font-family:'Nunito',sans-serif;font-size:56px;font-weight:900;color:var(--blue);line-height:1}
.stat-suffix{font-size:32px;font-weight:900;color:var(--teal)}
.stat-label{font-size:13px;color:#556B4C;text-transform:uppercase;letter-spacing:.8px;font-weight:700;margin-top:6px}

/* PLANOS */
.plans{background:white;padding:80px 0}
.plans-header{text-align:center;margin-bottom:48px}
.section-label{display:inline-flex;align-items:center;gap:6px;background:var(--blue-pale);color:var(--blue);font-size:12px;font-weight:800;padding:6px 14px;border-radius:50px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px}
.section-title{font-family:'Nunito',sans-serif;font-size:clamp(28px,4vw,44px);font-weight:900;color:var(--blue-dark);text-transform:uppercase;line-height:1.1}
.section-title .accent{color:var(--blue)}
.plans-grid{max-width:980px;margin:0 auto;padding:0 32px;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.plan-card{background:white;border:2px solid #E7F5E2;border-radius:20px;padding:32px 24px 28px;text-align:center;transition:all .3s;position:relative;box-shadow:0 6px 24px rgba(46,158,34,.06)}
.plan-card:hover{transform:translateY(-8px);box-shadow:0 20px 48px rgba(46,158,34,.14);border-color:var(--blue)}
.plan-card.featured{background:var(--blue-dark);border-color:var(--blue-dark);transform:scale(1.04)}
.plan-card.featured:hover{transform:scale(1.04) translateY(-8px);box-shadow:0 24px 56px rgba(19,63,9,.35)}
.plan-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--teal);color:white;font-size:11px;font-weight:800;padding:5px 20px;border-radius:50px;white-space:nowrap;text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:4px;box-shadow:0 4px 12px rgba(242,169,0,.4)}
.plan-speed{font-family:'Nunito',sans-serif;font-size:54px;font-weight:900;color:var(--blue);line-height:1;margin-bottom:4px}
.plan-card.featured .plan-speed{color:var(--teal)}
.plan-speed-unit{font-size:20px;font-weight:700}
.plan-tv{display:inline-flex;align-items:center;gap:6px;background:var(--blue-pale);color:var(--blue);font-size:12px;font-weight:700;padding:5px 14px;border-radius:50px;margin:12px 0 20px;text-transform:uppercase;letter-spacing:.3px}
.plan-card.featured .plan-tv{background:rgba(255,255,255,.15);color:rgba(255,255,255,.9)}
.plan-divider{width:36px;height:2px;background:#DEEFD8;margin:0 auto 20px}
.plan-card.featured .plan-divider{background:rgba(255,255,255,.2)}
.plan-features{list-style:none;text-align:left;margin-bottom:24px;display:flex;flex-direction:column;gap:8px}
.plan-features li{display:flex;align-items:center;gap:8px;font-size:14px;color:#556B4C}
.plan-card.featured .plan-features li{color:rgba(255,255,255,.8)}
.plan-check{color:var(--teal);font-weight:900;font-size:16px}
.plan-price-label{font-size:12px;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px}
.plan-card.featured .plan-price-label{color:rgba(255,255,255,.5)}
.plan-price{font-family:'Nunito',sans-serif;font-size:38px;font-weight:900;color:var(--blue-dark);line-height:1.1;margin:4px 0}
.plan-card.featured .plan-price{color:white}
.plan-price-note{font-size:12px;color:#94a3b8;margin-bottom:24px}
.plan-card.featured .plan-price-note{color:rgba(255,255,255,.5)}
.btn-plan{display:block;width:100%;padding:11px;border-radius:50px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;text-align:center;background:white;color:var(--blue);border:2px solid var(--blue);transition:all .25s;text-transform:uppercase;letter-spacing:.3px}
.btn-plan:hover{background:var(--blue);color:white;transform:translateY(-2px);box-shadow:0 8px 20px rgba(46,158,34,.25)}
.plan-card.featured .btn-plan{background:var(--teal);color:white;border-color:var(--teal)}
.plan-card.featured .btn-plan:hover{background:#C88E00;border-color:#C88E00;box-shadow:0 8px 20px rgba(242,169,0,.3)}

/* APPS INCLUSOS */
.apps-section{background:var(--blue-dark);padding:80px 0;position:relative;overflow:hidden}
.apps-section::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(242,169,0,.12) 1px,transparent 1px);background-size:26px 26px;pointer-events:none}
.apps-inner{max-width:1100px;margin:0 auto;padding:0 32px;position:relative;z-index:1}
.apps-header{text-align:center;margin-bottom:48px}
.apps-header .section-title{color:white}
.apps-header .section-title .accent{color:var(--teal)}
.apps-sub{font-size:15px;color:rgba(255,255,255,.6);max-width:520px;margin:10px auto 0;line-height:1.6}
.apps-note{display:inline-flex;align-items:center;gap:8px;background:rgba(242,169,0,.15);border:1px solid rgba(242,169,0,.35);color:#FFE468;font-size:12px;font-weight:700;padding:6px 16px;border-radius:50px;margin-top:16px}
.apps-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px}
.apps-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:28px 20px;text-align:center;transition:all .3s}
.apps-card:hover{background:rgba(255,255,255,.1);border-color:rgba(242,169,0,.4);transform:translateY(-6px)}
.apps-icon{width:52px;height:52px;border-radius:14px;background:rgba(242,169,0,.15);color:var(--teal);display:flex;align-items:center;justify-content:center;margin:0 auto 16px}
.apps-name{font-family:'Nunito',sans-serif;font-size:17px;font-weight:900;color:white;margin-bottom:8px}
.apps-logo{height:44px;display:flex;align-items:center;justify-content:center;margin-bottom:18px}
.apps-logo img{max-height:100%;max-width:100%;width:auto;object-fit:contain}
.apps-desc{font-size:13px;color:rgba(255,255,255,.6);line-height:1.55}

/* ABOUT */
.about{display:flex;min-height:480px;overflow:hidden}
.about-visual{flex:0 0 48%;position:relative;overflow:hidden;min-height:480px;background:var(--blue-dark)}
.about-visual img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
.about-visual::after{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(19,63,9,.3) 0%,transparent 60%);pointer-events:none}
.about-right{flex:1;background:white;display:flex;align-items:center;padding:56px 52px;border-left:1px solid #EAF7E6}
.about-content{max-width:480px}
.about-title{font-family:'Nunito',sans-serif;font-size:clamp(24px,3vw,36px);font-weight:900;text-transform:uppercase;line-height:1.1;margin-bottom:16px;color:var(--blue-dark)}
.about-title .accent{color:var(--blue)}
.about-text{font-size:15px;color:#556B4C;line-height:1.75;margin-bottom:28px}
.about-items{display:flex;flex-direction:column;gap:14px;margin-bottom:32px}
.about-item{display:flex;align-items:center;gap:14px;font-size:15px;font-weight:600;color:var(--blue-dark)}
.about-item-icon{width:40px;height:40px;border-radius:10px;background:var(--blue-pale);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--blue)}

/* COBERTURA */
.cobertura{background:var(--gray-bg);padding:80px 0}
.cobertura-inner{max-width:1100px;margin:0 auto;padding:0 32px;display:flex;gap:64px;align-items:center}
.cobertura-text{flex:1}
.cobertura-sub{font-size:15px;color:#556B4C;margin:12px 0 28px;line-height:1.7;max-width:440px}
.cidades-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:32px}
.cidade-item{background:white;border:1px solid #DEEFD8;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:10px;transition:all .2s}
.cidade-item:hover{border-color:var(--blue);transform:translateX(4px)}
.cidade-dot{width:8px;height:8px;border-radius:50%;background:var(--teal);flex-shrink:0}
.cidade-name{font-size:14px;font-weight:700;color:var(--blue-dark)}
.cobertura-map{flex:0 0 420px;background:var(--blue-dark);border-radius:24px;height:320px;position:relative;overflow:hidden;background-image:radial-gradient(circle,rgba(242,169,0,.1) 1px,transparent 1px);background-size:22px 22px}
.cobertura-map::before,.cobertura-map::after{display:none}
.cov-lines{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}
.cov-line{stroke:rgba(242,169,0,.3);stroke-width:.8;stroke-dasharray:4 4;animation:covDash 2s linear infinite}
@keyframes covDash{0%{stroke-dashoffset:0}100%{stroke-dashoffset:-16}}
.cov-node{position:absolute;transform:translate(-50%,-50%)}
.cov-dot{width:11px;height:11px;border-radius:50%;background:var(--teal);box-shadow:0 0 6px var(--teal),0 0 18px rgba(242,169,0,.7);position:relative;z-index:2}
.cov-pulse{position:absolute;top:50%;left:50%;width:11px;height:11px;border-radius:50%;border:1.5px solid rgba(242,169,0,.7);transform:translate(-50%,-50%);animation:covPulse 2.5s ease-out infinite;pointer-events:none}
@keyframes covPulse{0%{transform:translate(-50%,-50%) scale(1);opacity:.9}100%{transform:translate(-50%,-50%) scale(5);opacity:0}}
.cov-label{position:absolute;font-size:11px;font-weight:700;color:white;white-space:nowrap;background:rgba(0,15,45,.85);padding:4px 9px;border-radius:6px;border:1px solid rgba(242,169,0,.25);line-height:1;z-index:3;backdrop-filter:blur(4px)}
.cov-footer{position:absolute;bottom:0;left:0;right:0;padding:14px 20px 18px;text-align:center;z-index:3;background:linear-gradient(to top,rgba(19,63,9,.95) 0%,transparent 100%)}
.cov-footer-title{font-size:14px;font-weight:800;color:white;letter-spacing:.3px}
.cov-footer-sub{font-size:12px;color:rgba(255,255,255,.45);margin-top:3px}
.cov-center-icon{position:absolute;left:50%;top:42%;transform:translate(-50%,-50%);width:36px;height:36px;border-radius:50%;background:rgba(242,169,0,.12);border:1px solid rgba(242,169,0,.3);display:flex;align-items:center;justify-content:center;z-index:1;color:var(--teal)}
@keyframes pulseRing{0%{transform:scale(.8);opacity:0}50%{opacity:1}100%{transform:scale(1.3);opacity:0}}
.btn-whatsapp{display:inline-flex;align-items:center;gap:10px;background:#25D366;color:white;font-family:'Nunito',sans-serif;font-size:15px;font-weight:800;padding:14px 32px;border-radius:50px;transition:all .25s;box-shadow:0 8px 24px rgba(37,211,102,.3)}
.btn-whatsapp:hover{background:#1db954;transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,211,102,.4)}

/* DEPOIMENTOS */
.depoimentos{background:white;padding:80px 0}
.depoimentos-header{text-align:center;margin-bottom:48px;padding:0 20px}
.depo-carousel-wrap{max-width:1100px;margin:0 auto;padding:0 32px;overflow:hidden}
.depo-track{display:flex;gap:24px;transition:transform .5s cubic-bezier(.25,.46,.45,.94)}
.depo-card{flex:0 0 calc((100% - 48px) / 3);background:var(--gray-bg);border-radius:20px;padding:28px 24px;border:1px solid #EAF7E6;transition:box-shadow .3s,border-color .3s}
.depo-card:hover{box-shadow:0 12px 36px rgba(46,158,34,.1);border-color:#CDE9C4}
.depo-quote{font-size:48px;font-weight:900;color:var(--blue-pale);line-height:.8;margin-bottom:10px;font-family:'Nunito',sans-serif}
.depo-text{font-size:14px;color:#556B4C;line-height:1.65;margin-bottom:14px}
.depo-stars{color:var(--amber);font-size:16px;letter-spacing:2px;margin-bottom:18px}
.depo-author{display:flex;align-items:center;gap:12px}
.depo-avatar{width:44px;height:44px;min-width:44px;border-radius:50%;overflow:hidden;border:2px solid var(--blue-pale);background:var(--blue)}
.depo-avatar img{width:100%;height:100%;object-fit:cover;display:block}
.depo-name{font-size:13px;font-weight:800;color:var(--blue-dark)}
.depo-city{font-size:11px;color:#94a3b8;margin-top:2px}
.depo-dots{display:flex;justify-content:center;gap:7px;margin-top:28px}
.depo-dot{width:8px;height:8px;border-radius:50%;background:#DEEFD8;border:none;cursor:pointer;padding:0;transition:all .3s}
.depo-dot.active{background:var(--blue);width:22px;border-radius:4px}

/* FAQ */
.faq{background:var(--gray-bg);padding:80px 0}
.faq-header{text-align:center;margin-bottom:48px}
.faq-list{max-width:720px;margin:0 auto;padding:0 32px;display:flex;flex-direction:column;gap:12px}
.faq-item{background:white;border-radius:14px;border:1px solid #E7F5E2;overflow:hidden;transition:all .25s}
.faq-item:hover{border-color:#CDE9C4;box-shadow:0 2px 12px rgba(46,158,34,.06)}
.faq-item.open{border-color:var(--blue);box-shadow:0 6px 24px rgba(46,158,34,.1);border-left:3px solid var(--blue)}
.faq-question{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;cursor:pointer;font-size:15px;font-weight:700;color:var(--blue-dark);gap:16px}
.faq-icon{width:24px;height:24px;border-radius:50%;background:var(--blue-pale);color:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .3s,background .2s}
.faq-item.open .faq-icon{transform:rotate(45deg);background:var(--blue);color:white}
.faq-answer{max-height:0;overflow:hidden;transition:max-height .3s ease}
.faq-item.open .faq-answer{max-height:200px}
.faq-answer-inner{padding:0 24px 20px;font-size:14px;color:#556B4C;line-height:1.7}

/* FOOTER */
.footer{background:var(--blue-dark);color:white;padding:52px 0 28px}
.footer-inner{max-width:700px;margin:0 auto;padding:0 32px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:24px}
.footer-logo-wrap{opacity:.95}
.footer-tagline{font-size:14px;color:rgba(255,255,255,.45);line-height:1.5}
.footer-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
.footer-btn{display:flex;align-items:center;gap:8px;padding:11px 20px;border-radius:50px;font-size:13px;font-weight:700;color:white;text-decoration:none;border:1px solid rgba(255,255,255,.18);transition:all .25s}
.footer-btn:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.4)}
.footer-btn-ig{background:linear-gradient(135deg,rgba(131,58,180,.35),rgba(253,29,29,.3),rgba(252,176,69,.25));border-color:rgba(255,255,255,.1)}
.footer-btn-ig:hover{background:linear-gradient(135deg,rgba(131,58,180,.55),rgba(253,29,29,.45),rgba(252,176,69,.4))}
.footer-btn-wa{background:rgba(37,211,102,.15);border-color:rgba(37,211,102,.35)}
.footer-btn-wa:hover{background:rgba(37,211,102,.28);border-color:rgba(37,211,102,.6)}
.footer-divider{width:100%;height:1px;background:rgba(255,255,255,.08);margin:4px 0}
.footer-copy{font-size:12px;color:rgba(255,255,255,.28);text-align:center}

/* WHATSAPP FLOAT */
.whatsapp-float{position:fixed;bottom:28px;right:24px;z-index:9998;width:58px;height:58px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(37,211,102,.5);transition:all .25s;animation:waBounce 3s ease infinite}
@keyframes waBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.whatsapp-float:hover{transform:scale(1.1)!important;animation:none;box-shadow:0 10px 32px rgba(37,211,102,.6)}
.whatsapp-float svg{width:30px;height:30px}

/* REVEAL ANIMATIONS */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.from-left{transform:translateX(-32px)}
.from-right{transform:translateX(32px)}
.reveal.visible.from-left,.reveal.visible.from-right{transform:translateX(0)}
.reveal-delay-1{transition-delay:.1s}
.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}
.reveal-delay-4{transition-delay:.4s}

/* VIA CHAT MODAL */
.via-overlay{position:fixed;inset:0;background:rgba(19,63,9,.65);backdrop-filter:blur(5px);z-index:10000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;visibility:hidden;transition:opacity .3s,visibility .3s}
.via-overlay.open{opacity:1;visibility:visible}
.via-modal{background:white;border-radius:20px;width:100%;max-width:440px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,.3);transform:translateY(24px) scale(.97);transition:transform .3s cubic-bezier(.34,1.56,.64,1);max-height:90vh}
.via-overlay.open .via-modal{transform:translateY(0) scale(1)}
.via-modal-header{background:var(--blue-dark);padding:14px 18px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.via-header-avatar{width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.via-header-avatar img{width:30px;height:auto}
.via-header-info{flex:1}
.via-header-name{color:white;font-weight:800;font-size:15px;line-height:1.2}
.via-header-status{color:rgba(255,255,255,.7);font-size:12px;display:flex;align-items:center;gap:5px;margin-top:2px}
.via-status-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;animation:statusPulse 2s ease infinite}
@keyframes statusPulse{0%,100%{opacity:1}50%{opacity:.5}}
.via-header-close{background:rgba(255,255,255,.12);border:none;color:white;width:34px;height:34px;border-radius:50%;cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0}
.via-header-close:hover{background:rgba(255,255,255,.22)}
.via-messages{flex:1;overflow-y:auto;padding:18px 14px;display:flex;flex-direction:column;gap:8px;background:#EEF2FA;min-height:280px;max-height:440px}
.via-row{display:flex;align-items:flex-end;gap:7px}
.via-row.right{justify-content:flex-end}
.via-bot-ava{width:26px;height:26px;border-radius:50%;background:var(--blue-dark);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-bottom:2px}
.via-bot-ava img{width:17px;height:auto}
.via-bubble{max-width:76%;padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.5}
.via-bubble.bot{background:white;color:var(--blue-dark);border-bottom-left-radius:4px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.via-bubble.user{background:var(--blue);color:white;border-bottom-right-radius:4px}
.via-typing-row{display:flex;align-items:flex-end;gap:7px}
.via-typing-bubble{background:white;padding:10px 14px;border-radius:16px;border-bottom-left-radius:4px;display:flex;gap:4px;align-items:center;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.via-dot{width:7px;height:7px;border-radius:50%;background:#94a3b8;animation:viaDot 1.1s ease infinite}
.via-dot:nth-child(2){animation-delay:.18s}
.via-dot:nth-child(3){animation-delay:.36s}
@keyframes viaDot{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}
.via-plans-wrap{display:flex;flex-direction:column;gap:7px;padding-left:33px;width:100%}
.via-plan-btn{background:white;border:2px solid #DEEFD8;border-radius:12px;padding:11px 14px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:all .2s;width:100%;position:relative;text-align:left}
.via-plan-btn:hover{border-color:var(--blue);background:var(--blue-pale)}
.via-plan-btn.pick{border-color:var(--blue);background:var(--blue-pale);pointer-events:none}
.via-plan-speed{font-family:'Nunito',sans-serif;font-size:17px;font-weight:900;color:var(--blue)}
.via-plan-desc{font-size:11px;color:#64748b;margin-top:1px}
.via-plan-price-wrap{text-align:right}
.via-plan-price{font-size:14px;font-weight:800;color:var(--blue-dark)}
.via-plan-fixed{font-size:10px;color:#94a3b8}
.via-plan-tag{position:absolute;top:-9px;right:10px;background:var(--teal);color:white;font-size:9px;font-weight:800;padding:2px 9px;border-radius:50px;text-transform:uppercase;letter-spacing:.3px}
.via-input-bar{padding:12px 14px;background:white;border-top:1px solid #EAF7E6;display:flex;gap:9px;align-items:center;flex-shrink:0}
.via-input{flex:1;border:2px solid #DEEFD8;border-radius:50px;padding:10px 16px;font-size:14px;outline:none;transition:border-color .2s;font-family:'Nunito',sans-serif;color:var(--blue-dark)}
.via-input:focus{border-color:var(--blue)}
.via-input::placeholder{color:#94a3b8}
.via-send{width:42px;height:42px;background:var(--blue);color:white;border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .2s,transform .15s}
.via-send:hover{background:var(--blue-dark);transform:scale(1.08)}
.via-wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:#25D366;color:white;padding:13px 18px;border-radius:12px;font-family:'Nunito',sans-serif;font-weight:800;font-size:14px;cursor:pointer;border:none;width:100%;margin-top:4px;transition:all .2s;text-decoration:none;box-shadow:0 4px 16px rgba(37,211,102,.35)}
.via-wa-btn:hover{background:#1db954;transform:translateY(-2px)}

/* ===== TRABALHE CONOSCO ===== */
.jobs-section{background:#F5FBF3;padding:96px 0}
.jobs-inner{max-width:860px;margin:0 auto;padding:0 32px}
.jobs-header{text-align:center;margin-bottom:52px}
.jobs-title{font-family:'Nunito',sans-serif;font-size:44px;font-weight:900;color:var(--blue-dark);line-height:1.1;margin:0 0 14px}
.jobs-sub{font-size:17px;color:#6B7280;line-height:1.7}
.jobs-form-card{background:white;border-radius:24px;padding:40px 48px;box-shadow:0 4px 32px rgba(46,158,34,.08);border:1px solid #E7F5E2}
.jobs-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.jobs-field{display:flex;flex-direction:column;gap:7px}
.jobs-field.full{grid-column:1/-1}
.jobs-field label{font-size:12px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.4px}
.jobs-field input,.jobs-field select,.jobs-field textarea{border:1.5px solid #E7F5E2;border-radius:10px;padding:13px 16px;font-family:'Nunito',sans-serif;font-size:14px;color:#111827;transition:border-color .25s,box-shadow .25s;outline:none;background:#FAFDF9;appearance:none}
.jobs-field input:focus,.jobs-field select:focus,.jobs-field textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(46,158,34,.08);background:white}
.jobs-field textarea{resize:vertical;min-height:100px}
.jobs-select-wrap{position:relative}
.jobs-select-wrap select{width:100%}
.jobs-select-wrap::after{content:'';position:absolute;right:14px;top:50%;transform:translateY(-50%);border:5px solid transparent;border-top-color:#6B7280;pointer-events:none}
.jobs-submit{margin-top:28px;text-align:center}
.jobs-note{margin-top:14px;font-size:13px;color:#9CA3AF;text-align:center;line-height:1.6}
.jobs-file-wrap{position:relative}
.jobs-file-input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.jobs-file-label{display:flex;align-items:center;gap:12px;border:2px dashed #D1DDED;border-radius:10px;padding:16px 18px;cursor:pointer;transition:border-color .25s,background .25s;background:#FAFDF9;color:#6B7280;font-size:14px;font-weight:600}
.jobs-file-label:hover,.jobs-file-wrap:focus-within .jobs-file-label{border-color:var(--blue);background:#EEF3FF;color:var(--blue)}
.jobs-file-label svg{flex-shrink:0;color:inherit}
.jobs-file-label.has-file{border-color:#22c55e;background:#F0FDF4;color:#15803D}
.jobs-success{display:none;text-align:center;padding:32px;background:#F0FDF4;border-radius:16px;border:1.5px solid #86EFAC}
.jobs-success-icon{font-size:40px;margin-bottom:12px}
.jobs-success h3{font-size:20px;font-weight:800;color:#15803D;margin:0 0 8px}
.jobs-success p{color:#166534;font-size:14px;line-height:1.6;margin:0}

