<script>
// COUNTDOWN
(function(){
  const now=new Date(),expiry=new Date(now);
  expiry.setHours(23,59,59,999);
  if(now>expiry)expiry.setDate(expiry.getDate()+1);
  function pad(n){return String(n).padStart(2,'0')}
  function flip(el,val){el.classList.add('flip');setTimeout(()=>{el.textContent=val;el.classList.remove('flip')},120)}
  let lH,lM,lS;
  function tick(){
    const d=expiry-new Date();if(d<=0){expiry.setDate(expiry.getDate()+1);return}
    const h=pad(Math.floor(d/3600000)),m=pad(Math.floor((d%3600000)/60000)),s=pad(Math.floor((d%60000)/1000));
    const eH=document.getElementById('cd-h'),eM=document.getElementById('cd-m'),eS=document.getElementById('cd-s');
    if(eH&&h!==lH){flip(eH,h);lH=h}if(eM&&m!==lM){flip(eM,m);lM=m}if(eS&&s!==lS){flip(eS,s);lS=s}
  }
  tick();setInterval(tick,1000);
})();

// HERO CAROUSEL
const slides=document.querySelectorAll('.hero-slide'),dots=document.querySelectorAll('.hero-dot');
let cur=0;
function goSlide(n){slides[cur].classList.remove('active');dots[cur].classList.remove('active');cur=n;slides[cur].classList.add('active');dots[cur].classList.add('active')}
setInterval(()=>goSlide((cur+1)%slides.length),5000);


// REVEAL
const ro=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target)}})},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

// COUNTER
const co=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){animCount(e.target);co.unobserve(e.target)}})},{threshold:.5});
document.querySelectorAll('.stat-val').forEach(el=>co.observe(el));
function animCount(el){const t=+el.dataset.target,d=1800,s=16,steps=d/s;let i=0;const iv=setInterval(()=>{i++;el.textContent=Math.round(t*Math.min(i/steps,1));if(i>=steps)clearInterval(iv)},s)}

// FAQ
function toggleFaq(item){const isOpen=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));if(!isOpen)item.classList.add('open')}
